DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

DATABASE_URL=postgres://analytics_user:analytics_password@postgres:5432/analytics_bot
READONLY_DB_USER=analytics_readonly
READONLY_DB_PASSWORD=change-me

REDIS_URL=redis://redis:6379/0

N8N_API_KEY_SEED=change-me

MEDIA_URL=/media/
MEDIA_ROOT=/app/media

CHART_MAX_WIDTH_PX=1080
CHART_DEFAULT_DPI=150

IDEMPOTENCY_CACHE_TTL_SECONDS=86400

FLEXIBLE_QUERY_LLM_PROVIDER=openai
FLEXIBLE_QUERY_LLM_MODEL=gpt-4o-mini
FLEXIBLE_QUERY_LLM_API_KEY=
FLEXIBLE_QUERY_MIN_CONFIDENCE=0.6
FLEXIBLE_QUERY_TIMEOUT_SECONDS=8

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
